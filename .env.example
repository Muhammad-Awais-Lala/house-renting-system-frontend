# Gemini API Configuration (Optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
APP_URL="MY_APP_URL"

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# ============================================
# REQUIRED: Backend API Configuration
# ============================================
